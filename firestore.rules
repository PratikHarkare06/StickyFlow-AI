rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User notes: only the owner can read/write ────────────────────────────────
    match /users/{userId}/notes/{noteId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Validate writes — ensure required fields & correct types
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.content is string
        && request.resource.data.category is string
        && request.resource.data.color is string
        && request.resource.data.isPinned is bool
        && request.resource.data.isCompleted is bool
        && request.resource.data.isArchived is bool;

      allow update: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Deny all other access by default ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
